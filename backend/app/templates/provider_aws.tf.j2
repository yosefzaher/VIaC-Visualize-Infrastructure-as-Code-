# ──────────────────────────────────────────────────────────────
# VIaC – Terraform / AWS Provider Configuration
# ──────────────────────────────────────────────────────────────
# Rendered once per deployment, regardless of how many resources
# are included.  Variables:
#   • region  (str)  – AWS region, e.g. "us-east-1"
# ──────────────────────────────────────────────────────────────

terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ region }}"
}
