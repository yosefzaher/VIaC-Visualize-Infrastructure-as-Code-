# ──────────────────────────────────────────────────────────────
# VIaC – Jinja2 → HCL  Terraform Template: AWS EC2 Instance
# ──────────────────────────────────────────────────────────────
# Injected by the engine:
#   • node_id                   (str)  – Terraform resource identifier
# Properties:
#   • name                      (str)  – Human-readable name (used in tags)
#   • ami                       (str)  – AMI ID, e.g. "ami-0c02fb55956c7d316"
#   • instance_type             (str)  – Instance type, e.g. "t2.micro"
#   • subnet_id                 (str)  – Subnet ID or ref:node_id.id
#   • vpc_security_group_ids    (list) – List of SG IDs or refs (optional)
#   • key_name                  (str)  – SSH key pair name (optional)
#   • associate_public_ip       (bool) – Associate a public IP (default: true)
#   • environment               (str)  – Environment tag (default: "dev")
#   • tags                      (dict) – Optional extra tags
# ──────────────────────────────────────────────────────────────

resource "aws_instance" "{{ node_id }}" {
  ami                         = {{ ami | hcl_value }}
  instance_type               = {{ instance_type | hcl_value }}
  subnet_id                   = {{ subnet_id | hcl_value }}
{% if vpc_security_group_ids is defined and vpc_security_group_ids %}
  vpc_security_group_ids      = {{ vpc_security_group_ids | hcl_value }}
{% endif %}
{% if key_name is defined and key_name %}
  key_name                    = {{ key_name | hcl_value }}
{% endif %}
  associate_public_ip_address = {{ (associate_public_ip | default(true)) | hcl_value }}

  tags = {
    Name        = "{{ name | default(node_id) }}"
    ManagedBy   = "VIaC"
    Environment = "{{ environment | default('dev') }}"
{% for key, value in (tags | default({})).items() %}
    {{ key }} = "{{ value }}"
{% endfor %}
  }
}

output "instance_id_{{ node_id }}" {
  description = "The Instance ID of '{{ node_id }}' created by VIaC"
  value       = aws_instance.{{ node_id }}.id
}

output "public_ip_{{ node_id }}" {
  description = "The Public IP of '{{ node_id }}'"
  value       = aws_instance.{{ node_id }}.public_ip
}
